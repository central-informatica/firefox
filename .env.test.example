# Configuração para TESTES
# IMPORTANTE: Copie este arquivo para .env.test e configure com suas credenciais
# NUNCA use o banco de produção/desenvolvimento aqui!

DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@HOST:5432/xsecurity_test
MASTER_KEY=test_master_key_for_tests
CERT_STORAGE_DIR=storage/certificados
AUTH_SERVICE_URL=http://localhost:8001
