# SECURITY: Replace ALL values below with your own secrets before deployment
# NEVER use example values in production

# Master key for AES-GCM encryption (generate a strong random password)
MASTER_KEY=CHANGE_ME_use_a_strong_random_password_here

# PostgreSQL database connection (update credentials)
DATABASE_URL=postgresql+psycopg2://YOUR_USER:YOUR_PASSWORD@127.0.0.1:5432/certprot

# CORS allowed origins (update for production domain)
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Microservices URLs
AUTH_SERVICE_URL=http://127.0.0.1:8001
COFRE_SERVICE_URL=http://127.0.0.1:8002

# Cofre service API key (generate a new secure key)
COFRE_SERVICE_API_KEY=CHANGE_ME_generate_a_secure_api_key

# Debug mode - MUST be false in production (enables HTTPS-only cookies)
DEBUG=false

# Frontend backend URL
VITE_URL_BACKEND=http://127.0.0.1:8000

# Certificate storage directory
CERT_STORAGE_DIR=storage/certificados
